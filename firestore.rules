rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bloodTestRecords
    // Document ID: auto-generated
    // Fields:
    //   - patientName: string (required, max 100 chars)
    //   - patientId: string (required, max 50 chars)
    //   - bloodGroup: string (required, enum: ['A', 'B', 'AB', 'O'])
    //   - rh: string (required, enum: ['+', '-'])
    //   - testDate: string (required, ISO 8601 format)
    //   - result: string (required, max 200 chars)
    //   - qualitySeal: string (required, max 100 chars)
    //   - responsiblePerson: string (required, max 100 chars)
    //   - signatureData: string (optional, base64 image data)
    //   - createdAt: string (required, ISO 8601 format)
    //   - unitId: string (optional, max 50 chars)
    //   - unitGroup: string (optional, enum: ['A', 'B', 'AB', 'O'])
    //   - unitRh: string (optional, enum: ['+', '-'])
    //   - observations: string (optional, max 1000 chars)
    //   - uid: string (required, matches creator's UID)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "ingbiomedico@ucihonda.com.co" && request.auth.token.email_verified == true)
        );
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidBloodGroup(group) {
      return group in ['A', 'B', 'AB', 'O'];
    }

    function isValidRh(rh) {
      return rh in ['+', '-'];
    }

    function isValidDateString(dateStr) {
      return dateStr is string &&
        dateStr.matches("^\\d{4}-\\d{2}-\\d{2}.*");
    }

    // Domain Validator
    function isValidBloodTestRecord(data) {
      return hasRequiredFields(['patientName', 'patientId', 'bloodGroup', 'rh', 'testDate', 'result', 'createdAt', 'uid']) &&
             data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 150 &&
             data.patientId is string && data.patientId.size() > 0 && data.patientId.size() <= 100 &&
             isValidBloodGroup(data.bloodGroup) &&
             isValidRh(data.rh) &&
             data.testDate is string &&
             data.result in ['Compatible', 'Incompatible', ''] &&
             data.createdAt is string &&
             (!('eps' in data) || (data.eps is string && data.eps.size() <= 150)) &&
             (!('age' in data) || (data.age is string && data.age.size() <= 20)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 20)) &&
             (!('zone' in data) || (data.zone is string && data.zone.size() <= 50)) &&
             (!('unitId' in data) || (data.unitId is string && data.unitId.size() <= 100)) &&
             (!('unitGroup' in data) || isValidBloodGroup(data.unitGroup)) &&
             (!('unitRh' in data) || isValidRh(data.unitRh)) &&
             (!('unitExpirationDate' in data) || (data.unitExpirationDate is string && data.unitExpirationDate.size() <= 100)) &&
             (!('irregularAntibodies' in data) || (data.irregularAntibodies is string && data.irregularAntibodies.size() <= 200)) &&
             (!('autocontrol' in data) || data.autocontrol in ['0', '+', '++', '+++', '++++', '']) &&
             (!('temperature' in data) || (data.temperature is string && data.temperature.size() <= 50)) &&
             (!('provider' in data) || data.provider in ['Hemolife', 'Hemocentro', 'Fueco', '']) &&
             (!('requestedHemoderivative' in data) || data.requestedHemoderivative in ['Globulos Rojos', 'Plasma Fresco Congelado', 'Plaquetas', '']) &&
             (!('requestType' in data) || data.requestType in ['Reserva', 'Transfusion', 'Urgencia Vital', '']) &&
             (!('qualitySeal' in data) || (data.qualitySeal is string && data.qualitySeal.size() <= 150)) &&
             (!('bacteriologist' in data) || (data.bacteriologist is string && data.bacteriologist.size() <= 150)) &&
             (!('registryNumber' in data) || (data.registryNumber is string && data.registryNumber.size() <= 100)) &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 150)) &&
             (!('responsiblePerson' in data) || (data.responsiblePerson is string && data.responsiblePerson.size() <= 150)) &&
             (!('hemoderivativeUnit' in data) || (data.hemoderivativeUnit is string && data.hemoderivativeUnit.size() <= 150)) &&
             (!('observations' in data) || (data.observations is string && data.observations.size() <= 2000)) &&
             data.uid == request.auth.uid;
    }

    // Domain Validator for Received Units
    function isValidReceivedUnitRecord(data) {
      return hasRequiredFields(['receptionDate', 'receptionTime', 'provider', 'hemoderivativeType', 'unitId', 'bloodGroup', 'rh', 'expirationDate', 'accepted', 'receiverName', 'supervisorName', 'createdAt', 'uid']) &&
             data.receptionDate is string && data.receptionDate.size() > 0 && data.receptionDate.size() <= 50 &&
             data.receptionTime is string && data.receptionTime.size() > 0 && data.receptionTime.size() <= 50 &&
             data.provider in ['Hemolife', 'Hemocentro', 'Fueco', ''] &&
             data.hemoderivativeType in ['Globulos Rojos', 'Plasma Fresco Congelado', 'Plaquetas', ''] &&
             data.unitId is string && data.unitId.size() > 0 && data.unitId.size() <= 100 &&
             isValidBloodGroup(data.bloodGroup) &&
             isValidRh(data.rh) &&
             data.expirationDate is string && data.expirationDate.size() > 0 && data.expirationDate.size() <= 50 &&
             data.accepted in ['Sí', 'No', ''] &&
             data.receiverName is string && data.receiverName.size() > 0 && data.receiverName.size() <= 150 &&
             data.supervisorName is string && data.supervisorName.size() > 0 && data.supervisorName.size() <= 150 &&
             data.createdAt is string &&
             (!('qualitySeal' in data) || (data.qualitySeal is string && data.qualitySeal.size() <= 100)) &&
             (!('volume' in data) || (data.volume is string && data.volume.size() <= 50)) &&
             (!('packagingIntegrity' in data) || data.packagingIntegrity in ['Íntegro', 'Dañado', '']) &&
             (!('contentAspect' in data) || data.contentAspect in ['Normal', 'Anormal', '']) &&
             (!('temperature' in data) || (data.temperature is string && data.temperature.size() <= 50)) &&
             (!('observations' in data) || (data.observations is string && data.observations.size() <= 2000)) &&
             (!('rejectionReason' in data) || (data.rejectionReason is string && data.rejectionReason.size() <= 500)) &&
             (!('actionsTaken' in data) || (data.actionsTaken is string && data.actionsTaken.size() <= 500)) &&
             (!('reporterName' in data) || (data.reporterName is string && data.reporterName.size() <= 150)) &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 150)) &&
             data.uid == request.auth.uid;
    }

    // Domain Validator for Transfusion Use
    function isValidTransfusionUseRecord(data) {
      return hasRequiredFields(['service', 'patientId', 'patientName', 'unitId', 'qualitySeal', 'transfusionDate', 'transfusionTime', 'createdAt', 'uid']) &&
             data['service'] is string && data['service'].size() <= 100 &&
             data.patientId is string && data.patientId.size() > 0 && data.patientId.size() <= 100 &&
             data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 150 &&
             data.unitId is string && data.unitId.size() > 0 && data.unitId.size() <= 100 &&
             data.qualitySeal is string && data.qualitySeal.size() > 0 && data.qualitySeal.size() <= 150 &&
             data.transfusionDate is string && data.transfusionDate.size() > 0 && data.transfusionDate.size() <= 50 &&
             data.transfusionTime is string && data.transfusionTime.size() > 0 && data.transfusionTime.size() <= 50 &&
             data.createdAt is string &&
             (!('age' in data) || (data.age is string && data.age.size() <= 20)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 20)) &&
             (!('hemoderivativeType' in data) || (data.hemoderivativeType is string && data.hemoderivativeType.size() <= 100)) &&
             (!('bloodGroup' in data) || (data.bloodGroup is string && data.bloodGroup.size() <= 10)) &&
             (!('rh' in data) || (data.rh is string && data.rh.size() <= 10)) &&
             (!('orderDate' in data) || (data.orderDate is string && data.orderDate.size() <= 50)) &&
             (!('orderTime' in data) || (data.orderTime is string && data.orderTime.size() <= 50)) &&
             (!('opportunity' in data) || (data.opportunity is string && data.opportunity.size() <= 100)) &&
             (!('prescriptionFormat' in data) || data.prescriptionFormat in ['Sí', 'No', '']) &&
             (!('informedConsent' in data) || data.informedConsent in ['Sí', 'No', '']) &&
             (!('adminChecklist' in data) || data.adminChecklist in ['Sí', 'No', '']) &&
             (!('adverseReaction' in data) || data.adverseReaction in ['Sí', 'No', '']) &&
             (!('safetyEvent' in data) || (data.safetyEvent is string && data.safetyEvent.size() <= 1000)) &&
             (!('reactionDescription' in data) || (data.reactionDescription is string && data.reactionDescription.size() <= 1000)) &&
             (!('responsibleDoctor' in data) || (data.responsibleDoctor is string && data.responsibleDoctor.size() <= 150)) &&
             (!('responsibleNurse' in data) || (data.responsibleNurse is string && data.responsibleNurse.size() <= 150)) &&
             (!('observations' in data) || (data.observations is string && data.observations.size() <= 2000)) &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 150)) &&
             (!('preVitalSigns' in data) || data.preVitalSigns is map) &&
             (!('duringVitalSigns' in data) || data.duringVitalSigns is map) &&
             (!('postVitalSigns' in data) || data.postVitalSigns is map) &&
             data.uid == request.auth.uid;
    }

    // Domain Validator for Final Disposition
    function isValidFinalDispositionRecord(data) {
      return hasRequiredFields(['unitId', 'dispositionDate', 'dispositionType', 'responsiblePerson', 'createdAt', 'uid']) &&
             data.unitId is string && data.unitId.size() > 0 && data.unitId.size() <= 100 &&
             data.dispositionDate is string && data.dispositionDate.size() > 0 && data.dispositionDate.size() <= 50 &&
             data.dispositionType in ['Transfundido', 'Descarte', 'Traslado', ''] &&
             data.responsiblePerson is string && data.responsiblePerson.size() > 0 && data.responsiblePerson.size() <= 150 &&
             data.createdAt is string &&
             (!('qualitySeal' in data) || (data.qualitySeal is string && data.qualitySeal.size() <= 100)) &&
             (!('reason' in data) || (data.reason is string && data.reason.size() <= 500)) &&
             (!('observations' in data) || (data.observations is string && data.observations.size() <= 2000)) &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 150)) &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /bloodTestRecords/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBloodTestRecord(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidBloodTestRecord(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /receivedUnits/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReceivedUnitRecord(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidReceivedUnitRecord(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /transfusionUse/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransfusionUseRecord(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidTransfusionUseRecord(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /finalDisposition/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFinalDispositionRecord(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidFinalDispositionRecord(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /app_settings/{documentId} {
      // Only admins can read/write settings. 
      // Server (Admin SDK) bypasses this.
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
